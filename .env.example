# ── Hermes Environment Configuration ─────────────────────────────────
# Copy this to ~/.hermes/.env (or ~/AppData/Local/hermes/.env on Windows)
# and fill in your actual keys.
#
# Core
# HERMES_HOME=                          # Override default home path

# Provider API Keys
# OPENROUTER_API_KEY=                   # OpenRouter
# ANTHROPIC_API_KEY=                    # Anthropic Claude
# OPENAI_API_KEY=                       # OpenAI
# GOOGLE_API_KEY=                       # Google Gemini
# DEEPSEEK_API_KEY=                     # DeepSeek
# XAI_API_KEY=                          # xAI / Grok
# HF_TOKEN=                             # HuggingFace
# GLM_API_KEY=                          # Z.AI / GLM
# MINIMAX_API_KEY=                      # MiniMax
# KIMI_API_KEY=                         # Kimi / Moonshot
# DASHSCOPE_API_KEY=                    # Alibaba / DashScope
# KILOCODE_API_KEY=                     # Kilo Code
# OPENCODE_ZEN_API_KEY=                 # OpenCode Zen
# OPENCODE_GO_API_KEY=                  # OpenCode Go

# Skills Hub (GitHub integration)
# GITHUB_TOKEN=                          # Personal Access Token for higher API rate limits

# Web Search & Extract
# EXA_API_KEY=
# PARALLEL_API_KEY=
# FIRECRAWL_API_KEY=
# TAVILY_API_KEY=
# SEARXNG_URL=

# Browser Automation
# AGENT_BROWSER_API_KEY=                # For cloud-based browser (Browserbase/Camofox)

# Image Generation
# FAL_KEY=                              # Fal.ai for image gen
# STABILITY_API_KEY=

# Voice / STT
# GROQ_API_KEY=                         # Groq Whisper
# VOICE_TOOLS_OPENAI_KEY=               # OpenAI Whisper (STT) + TTS
# MISTRAL_API_KEY=                      # Mistral Voxtral (STT) + TTS
# ELEVENLABS_API_KEY=                   # ElevenLabs TTS

# Messaging / Gateway
# TELEGRAM_BOT_TOKEN=
# DISCORD_BOT_TOKEN=
# SLACK_BOT_TOKEN=
# SLACK_APP_TOKEN=
# WHATSAPP_API_KEY=
# MATRIX_ACCESS_TOKEN=
# SIGNAL_NUMBER=
# MICROSOFT_TEAMS_TENANT_ID=
# MICROSOFT_TEAMS_CLIENT_ID=
# MICROSOFT_TEAMS_CLIENT_SECRET=

# MCP Servers (optional)
# FIGMA_ACCESS_TOKEN=
# GITHUB_APP_ID=
# GITHUB_APP_PRIVATE_KEY_PATH=
# GITHUB_APP_INSTALLATION_ID=

# Misc
# COPILOT_GITHUB_TOKEN=                 # GitHub Copilot provider
# OPENWEATHERMAP_API_KEY=               # Weather tool
